{
  "name": "@1click/ui",
  "version": "0.0.1",
  "private": true,
  "description": "Shared frontend UI component library for 1click storefronts. Source-shipped, consumed via git install.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1click-so/1click-ui.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "docs",
    "README.md",
    "KNOWN_ISSUES.md",
    "tailwind-preset.js",
    "tsconfig.json"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": "^16.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.6.0"
  },
  "packageManager": "bun@1.2.0",
  "engines": {
    "node": ">=20"
  }
}
